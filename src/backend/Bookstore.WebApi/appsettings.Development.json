{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "bookstore-api",
    "Audience": "bookstore-api-clients"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "RateLimiting": {
    "Anonymous": {
      "PermitLimit": 1000,
      "WindowInSeconds": 60
    },
    "Authenticated": {
      "PermitLimit": 10000,
      "WindowInSeconds": 60
    }
  }
}
