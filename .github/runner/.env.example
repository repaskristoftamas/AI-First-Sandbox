# GitHub repository (owner/repo)
GITHUB_REPOSITORY=repaskristoftamas/Bookstore-API

# Personal access token with repo scope (used to register the runner)
GITHUB_PAT=ghp_your_token_here

# Runner display name in GitHub Settings → Actions → Runners
RUNNER_NAME=bookstore-runner

# Comma-separated labels applied to this runner
RUNNER_LABELS=self-hosted,linux,docker

# Path to your local ~/.claude directory (mounted read-only for subscription auth)
CLAUDE_AUTH_DIR=~/.claude
